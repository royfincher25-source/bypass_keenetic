# =============================================================================
# ШАБЛОН КОНФИГУРАЦИИ ДЛЯ BYPASS_KEENETIC
# =============================================================================
# Скопируйте этот файл в .env и заполните реальными значениями
# Команда: cp .env.example .env
#
# ВНИМАНИЕ: Файл .env содержит чувствительные данные и НЕ ДОЛЖЕН коммититься в git!
# =============================================================================

# -----------------------------------------------------------------------------
# TELEGRAM BOT SETTINGS
# -----------------------------------------------------------------------------
# Токен бота от @BotFather (формат: 123456789:ABCdefGHIjklMNOpqrsTUVwxyz)
TELEGRAM_BOT_TOKEN=

# Логины пользователей (без @), разделённые запятой
# Пример: TELEGRAM_USERNAMES=user1,user2,user3
TELEGRAM_USERNAMES=

# -----------------------------------------------------------------------------
# ROUTER SETTINGS
# -----------------------------------------------------------------------------
# IP-адрес роутера в локальной сети
ROUTER_IP=192.168.1.1

# -----------------------------------------------------------------------------
# LOCAL PORTS
# -----------------------------------------------------------------------------
# Локальный порт для Shadowsocks
LOCALPORT_SH=1082

# DNS порт для Tor (для доступа к .onion через браузер)
DNSPORT_TOR=9053

# Локальный порт для Tor
LOCALPORT_TOR=9141

# Локальный порт для VLESS
LOCALPORT_VLESS=10810

# Локальный порт для Trojan
LOCALPORT_TROJAN=10829

# Порт DNS-over-TLS
DNSOVER_TLS_PORT=40500

# Порт DNS-over-HTTPS
DNSOVER_HTTPS_PORT=40508

# -----------------------------------------------------------------------------
# BOT SETTINGS
# -----------------------------------------------------------------------------
# Максимальное количество попыток перезапуска бота при ошибке
MAX_RESTARTS=5

# Задержка между перезапусками (секунды)
RESTART_DELAY=60

# -----------------------------------------------------------------------------
# BACKUP SETTINGS
# -----------------------------------------------------------------------------
# Максимальный размер бэкапа (MB)
BACKUP_MAX_SIZE_MB=45

# -----------------------------------------------------------------------------
# BOTLIGHT SPECIFIC (только для облегчённой версии)
# -----------------------------------------------------------------------------
# Клиент для VLESS: singbox или xray
VLESS_CLIENT=singbox

# Режим работы singbox: tun или socks5 (для xray всегда socks5)
CLIENT_MODE=socks5

# Порт для Tor socks5 прокси
PROXY0_PORT=9050
PROXY0_INTERFACE=Proxy0

# Порт для xray
PROXY1_PORT=1080
PROXY1_INTERFACE=Proxy1

# Порт для singbox в режиме socks5
PROXY2_PORT=2080
PROXY2_INTERFACE=Proxy2

# -----------------------------------------------------------------------------
# URLs (не изменять без необходимости)
# -----------------------------------------------------------------------------
# Базовый URL для загрузки файлов
BASE_URL=https://raw.githubusercontent.com/royfincher25-source/bypass_keenetic/main

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
# Уровень логирования: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
